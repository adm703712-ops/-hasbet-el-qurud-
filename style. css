/* إعدادات الخط العام وتجربة المستخدم */
body {
    font-family: 'Tajawal', sans-serif;
    transition: all 0.3s ease;
}

/* تنسيق حقول الإدخال */
.input-field {
    @apply w-full px-4 py-3 rounded-xl border-2 border-slate-200 dark:border-slate-700 
    bg-white dark:bg-slate-900 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 
    outline-none transition-all duration-200 text-lg font-medium;
}

/* بطاقات النتائج مع تأثير تحويم */
.result-card {
    @apply p-5 rounded-3xl border shadow-sm flex flex-col items-center justify-center 
    text-center transition-transform duration-300 hover:scale-105;
}

/* تحسين مظهر الرسم البياني */
canvas {
    filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.05));
}

/* رسالة النجاح */
#successMessage {
    transition: opacity 0.5s ease-in-out;
}

