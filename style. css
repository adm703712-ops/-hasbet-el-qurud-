/* تخصيصات Tailwind الإضافية */
.input-field {
    @apply w-full px-5 py-4 rounded-2xl border-2 border-slate-100 bg-slate-50 dark:bg-slate-700 dark:border-slate-600 focus:border-blue-500 focus:ring-0 transition-all outline-none text-xl font-bold;
}

.result-card {
    @apply p-6 rounded-3xl border-2 flex flex-col items-center justify-center text-center shadow-sm;
}

/* إخفاء الأسهم الافتراضية في حقول الأرقام */
input::-webkit-outer-spin-button,
input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

/* تحسين استجابة الرسم البياني */
#loanChart {
    max-height: 100% !important;
    width: 100% !important;
}

button:active {
    transform: scale(0.97);
}

