class LoanCalculator {
    constructor() {
        this.inputs = {
            amount: document.getElementById('loanAmount'),
            rate: document.getElementById('interestRate'),
            term: document.getElementById('loanTerm'),
            fees: document.getElementById('adminFees')
        };
        
        this.outputs = {
            monthly: document.getElementById('monthlyPayment'),
            interest: document.getElementById('totalInterest'),
            total: document.getElementById('totalAmount')
        };

        this.calculateBtn = document.getElementById('calculateBtn');
        this.btnDownload = document.getElementById('downloadPDF');
        this.successMessage = document.getElementById('successMessage');
        this.chart = null;
        
        this.init();
    }

    init() {
        this.calculateBtn.addEventListener('click', () => {
            this.updateUI();
            this.showSuccessMessage();
        });

        this.btnDownload.addEventListener('click', () => this.generatePDF());
        
        // تشغيل أولي
        this.updateUI();
    }

    calculate() {
        const P = parseFloat(this.inputs.amount.value) || 0;
        const annualRate = (parseFloat(this.inputs.rate.value) || 0) / 100;
        const monthlyRate = annualRate / 12;
        const years = parseFloat(this.inputs.term.value) || 0;
        const n = years * 12;
        const fees = parseFloat(this.inputs.fees.value) || 0;

        if (P <= 0 || n <= 0) return null;

        let monthlyPayment = (monthlyRate === 0) ? P / n : 
            (P * monthlyRate * Math.pow(1 + monthlyRate, n)) / (Math.pow(1 + monthlyRate, n) - 1);

        const totalRepayment = (monthlyPayment * n) + fees;
        const totalInterest = totalRepayment - P - fees;

        return { monthly: monthlyPayment, interest: totalInterest, total: totalRepayment, principal: P, n, monthlyRate, fees };
    }

    updateUI() {
        const data = this.calculate();
        if (!data) return;

        const format = (num) => Math.round(num).toLocaleString('en-US'); // نستخدم التنسيق الأجنبي برمجياً لتجنب مشاكل الخطوط العربية في بعض المتصفحات

        this.outputs.monthly.innerText = format(data.monthly);
        this.outputs.interest.innerText = format(data.interest);
        this.outputs.total.innerText = format(data.total);

        this.renderChart(data.principal, data.interest + data.fees);
    }

    renderChart(principal, interest) {
        const ctx = document.getElementById('loanChart').getContext('2d');
        if (this.chart) this.chart.destroy();

        this.chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: ['أصل القرض', 'الفوائد والرسوم'],
                datasets: [{
                    data: [principal, interest],
                    backgroundColor: ['#2563eb', '#10b981'],
                    borderWidth: 0
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom', labels: { font: { family: 'Tajawal' } } } }
            }
        });
    }

    showSuccessMessage() {
        this.successMessage.classList.remove('hidden');
        setTimeout(() => this.successMessage.classList.add('hidden'), 2000);
    }

    generatePDF() {
        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();
        const data = this.calculate();
        
        if (!data) return alert("فضلاً أدخل بيانات صحيحة");

        doc.text("Loan Summary - Summary of Payment", 10, 10);
        doc.text(`Total Amount: ${Math.round(data.total)} SAR`, 10, 20);
        doc.text(`Monthly Payment: ${Math.round(data.monthly)} SAR`, 10, 30);
        
        alert("تم تجهيز البيانات! (ملاحظة: مكتبة PDF الأساسية تدعم الإنجليزية بشكل أفضل، سأساعدك لاحقاً في تعريبها بالكامل)");
        doc.save("loan-details.pdf");
    }
}

window.onload = () => new LoanCalculator();
